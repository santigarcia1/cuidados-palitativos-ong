<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="550"
            prefWidth="900"
            style="-fx-background-color: #2C3E50;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cuidados.paliativos.controlador.ControladorProfesionales">

    <!-- ENCABEZADO -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="10"
              style="-fx-background-color: #34495E; -fx-padding: 10;">

            <Label text="Gestión de Profesionales"
                   style="-fx-text-fill: white;
                          -fx-font-size: 18px;
                          -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- CONTENIDO -->
    <center>

        <VBox alignment="TOP_CENTER" spacing="15">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- FORMULARIO -->
            <GridPane hgap="15" vgap="10">

                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT" minWidth="150"/>
                    <ColumnConstraints halignment="LEFT" minWidth="250"/>
                </columnConstraints>

                <!-- NOMBRE -->
                <Label text="Nombre:"
                       style="-fx-text-fill: white;"/>

                <TextField fx:id="txtNombre"
                           prefWidth="250"
                           GridPane.columnIndex="1"/>

                <!-- APELLIDO -->
                <Label text="Apellido:"
                       style="-fx-text-fill: white;"
                       GridPane.rowIndex="1"/>

                <TextField fx:id="txtApellido"
                           prefWidth="250"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="1"/>

                <!-- ESPECIALIDAD -->
                <Label text="Especialidad:"
                       style="-fx-text-fill: white;"
                       GridPane.rowIndex="2"/>

                <ComboBox fx:id="cbEspecialidad"
                          prefWidth="250"
                          promptText="Seleccione una especialidad"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="2"/>

                <!-- TELEFONO -->
                <Label text="Teléfono:"
                       style="-fx-text-fill: white;"
                       GridPane.rowIndex="3"/>

                <TextField fx:id="txtTelefono"
                           prefWidth="250"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="3"/>

                <!-- USUARIO -->
                <Label text="Usuario:"
                       style="-fx-text-fill: white;"
                       GridPane.rowIndex="4"/>

                <ComboBox fx:id="cbUsuario"
                          prefWidth="250"
                          promptText="Seleccione un usuario"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="4"/>

            </GridPane>

            <!-- BOTONES -->
            <HBox alignment="CENTER" spacing="10">

                <Button text="Nuevo"
                        onAction="#nuevoProfesional"
                        style="-fx-background-color: #2980B9;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;"/>

                <Button text="Guardar"
                        onAction="#guardarProfesional"
                        style="-fx-background-color: #27AE60;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;"/>

                <Button text="Modificar"
                        onAction="#modificarProfesional"
                        style="-fx-background-color: #F39C12;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;"/>

                <Button text="Eliminar"
                        onAction="#eliminarProfesional"
                        style="-fx-background-color: #E74C3C;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;"/>

                <Button text="Consultar"
                        onAction="#consultarProfesional"
                        style="-fx-background-color: #8E44AD;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;"/>

            </HBox>

            <!-- TABLA -->
            <TableView fx:id="tablaProfesionales"
                       prefWidth="850"
                       style="-fx-background-color: #ECF0F1;
                              -fx-border-radius: 5;">

                <columns>

                    <TableColumn fx:id="colId"
                                 text="ID"
                                 prefWidth="60"/>

                    <TableColumn fx:id="colNombre"
                                 text="Nombre"
                                 prefWidth="140"/>

                    <TableColumn fx:id="colApellido"
                                 text="Apellido"
                                 prefWidth="140"/>

                    <TableColumn fx:id="colEspecialidad"
                                 text="Especialidad"
                                 prefWidth="180"/>

                    <TableColumn fx:id="colTelefono"
                                 text="Teléfono"
                                 prefWidth="140"/>

                    <TableColumn fx:id="colUsuario"
                                 text="Usuario"
                                 prefWidth="180"/>

                </columns>

            </TableView>

        </VBox>

    </center>

</BorderPane>