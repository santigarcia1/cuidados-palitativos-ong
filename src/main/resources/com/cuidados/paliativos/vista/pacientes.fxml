<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600"
            prefWidth="950"
            style="-fx-background-color: #2C3E50;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cuidados.paliativos.controlador.ControladorPacientes">

    <!-- ENCABEZADO -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="10"
              style="-fx-background-color: #34495E; -fx-padding: 10;">

            <Label text="Gestión de Pacientes"
                   style="-fx-text-fill: white;
                          -fx-font-size: 18px;
                          -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- CONTENIDO -->
    <center>

        <VBox alignment="TOP_CENTER" spacing="15">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- FORMULARIO -->
            <GridPane hgap="15" vgap="10">

                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT" minWidth="170"/>
                    <ColumnConstraints halignment="LEFT" minWidth="250"/>
                </columnConstraints>

                <!-- NOMBRE -->
                <Label text="Nombre:"
                       style="-fx-text-fill: white;"/>

                <TextField fx:id="txtNombre"
                           prefWidth="250"
                           GridPane.columnIndex="1"/>

                <!-- APELLIDO -->
                <Label text="Apellido:"
                       style="-fx-text-fill: white;"
                       GridPane.rowIndex="1"/>

                <TextField fx:id="txtApellido"
                           prefWidth="250"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="1"/>

                <!-- FECHA NACIMIENTO -->
                <Label text="Fecha de nacimiento:"
                       style="-fx-text-fill: white;"
                       GridPane.rowIndex="2"/>

                <DatePicker fx:id="dpFechaNacimiento"
                            prefWidth="250"
                            GridPane.columnIndex="1"
                            GridPane.rowIndex="2"/>

                <!-- DIRECCION -->
                <Label text="Dirección:"
                       style="-fx-text-fill: white;"
                       GridPane.rowIndex="3"/>

                <TextField fx:id="txtDireccion"
                           prefWidth="250"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="3"/>

                <!-- TELEFONO -->
                <Label text="Teléfono:"
                       style="-fx-text-fill: white;"
                       GridPane.rowIndex="4"/>

                <TextField fx:id="txtTelefono"
                           prefWidth="250"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="4"/>

                <!-- ESTADO -->
                <Label text="Estado:"
                       style="-fx-text-fill: white;"
                       GridPane.rowIndex="5"/>

                <ComboBox fx:id="cbEstado"
                          prefWidth="250"
                          promptText="Seleccione un estado"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="5"/>

            </GridPane>

            <!-- BOTONES -->
            <HBox alignment="CENTER" spacing="10">

                <Button fx:id="btnNuevo"
                        text="Limpiar campos"
                        onAction="#nuevoPaciente"/>

                <Button fx:id="btnGuardar"
                        text="Guardar"
                        onAction="#guardarPaciente"/>

                <Button fx:id="btnModificar"
                        text="Modificar"
                        onAction="#modificarPaciente"/>

                <Button fx:id="btnEliminar"
                        text="Eliminar"
                        onAction="#eliminarPaciente"/>

            </HBox>

            <!-- TABLA -->
            <TableView fx:id="tablaPacientes"
                       prefWidth="900"
                       style="-fx-background-color: #ECF0F1;
                              -fx-border-radius: 5;">

                <columns>

                    <TableColumn fx:id="colId"
                                 text="ID"
                                 prefWidth="60"/>

                    <TableColumn fx:id="colNombre"
                                 text="Nombre"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colApellido"
                                 text="Apellido"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colFechaNacimiento"
                                 text="Fecha Nacimiento"
                                 prefWidth="150"/>

                    <TableColumn fx:id="colDireccion"
                                 text="Dirección"
                                 prefWidth="220"/>

                    <TableColumn fx:id="colTelefono"
                                 text="Teléfono"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colEstado"
                                 text="Estado"
                                 prefWidth="120"/>

                </columns>

            </TableView>

        </VBox>

    </center>

</BorderPane>